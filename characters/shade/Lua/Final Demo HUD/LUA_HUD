addHook("PlayerThink", function(p)
	if not p.hudchanged
		p.hudchanged = false
	end
	
	if emw5chars[p.mo.skin] == true
		if not p.hudchanged
			if hud.enabled("lives")
				hud.disable("lives")
				p.hudchanged = true
			end
		elseif hud.enabled("lives")
			hud.disable("lives")
		end
	elseif p.hudchanged
		hud.enable("lives")
		p.hudchanged = false
	end
end)